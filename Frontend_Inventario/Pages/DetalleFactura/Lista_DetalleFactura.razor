@page "/Lista_DetalleFactura"
@using Frontend_Inventario.Modelos
@using Frontend_Inventario.Servicios
@using Frontend_Inventario.Servicios.iServicios

@inject DetalleFactura_Interface servicioDetalleFactura

<div class="row animated fadeIn fast">
    <div class="col-12">
        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-body">

                <div class="d-flex justify-content-between align-items-center">
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0">
                            <i class="bi bi-search text-muted"></i>
                        </span>
                        <input type="text" class="form-control border-0 shadow-sm rounded-start" placeholder="Buscar...." />
                    </div>

                    <NavLink href="Registrar_DetalleFactura" class="btn btn-primary rounded-pill shadow-sm ms-3 px-4">
                        <i class="bi bi-person-fill-add"></i> Nuevo
                    </NavLink>
                </div>

            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-12">
        <div class="card shadow-lg border-0 rounded-4">
            <div class="card-body">
                <h4 class="card-title">Detalle de Facturas</h4>
                <h6 class="card-subtitle mb-4 text-muted">Facturas registradas</h6>

                <div class="table-responsive">
                    <table class="table table-hover table-bordered align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>idDetalle</th>
                                <th>idFactura</th>
                                <th>idProducto</th>
                                <th>Cantidad</th>
                                <th>Precio Unitario</th>
                                <th>Descuento</th>
                                <th>Subtotal</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (detalleFactura_Modelo_Respuestas.Count() > 0)
                            {
                                @foreach (var item in detalleFactura_Modelo_Respuestas)
                                {
                                    <tr>
                                        <td>@item.idDetalle</td>
                                        <td>@item.idFactura</td>
                                        <td>@item.idProducto</td>
                                        <td>@item.cantidad</td>
                                        <td>@item.precioUnitario</td>
                                        <td>@item.descuento</td>
                                        <td>@item.subtotal</td>
                                        <td class="text-center">
                                            <!-- Botón de editar -->
                                            <NavLink href=@($"Registrar_DetalleFactura/{item.idDetalle}")
                                                     class="btn btn-warning rounded-circle shadow-sm"
                                                     data-bs-toggle="tooltip" data-bs-placement="top" title="Modificar">
                                                <i class="bi bi-pencil-fill"></i>
                                            </NavLink>
                                            <!-- Botón de eliminar -->
                                            <button class="btn btn-danger rounded-circle shadow-sm ms-2"
                                                    @onclick="() => EliminarDetalleFactura(item.idDetalle)"
                                                    data-bs-toggle="tooltip" data-bs-placement="top" title="Eliminar">
                                                <i class="bi bi-trash-fill"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="8" class="text-center text-muted">No hay registros disponibles</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Paginación -->
                <div class="d-flex justify-content-center mt-4 gap-3">
                    <button class="btn btn-outline-secondary rounded-pill px-4">Anteriores</button>
                    <button class="btn btn-outline-secondary rounded-pill px-4">Siguiente</button>
                </div>
            </div>
        </div>
    </div>
</div>



@code {
    public IEnumerable<Detalle_Factura_Modelo_Respuesta> detalleFactura_Modelo_Respuestas = new List<Detalle_Factura_Modelo_Respuesta>();

    protected override async Task OnInitializedAsync()
    {
        detalleFactura_Modelo_Respuestas = await servicioDetalleFactura.Get_DetalleFacturas();
    }

    public async Task EliminarDetalleFactura(int idDetalleFactura)
    {
        await servicioDetalleFactura.Eliminar_DetalleFactura(idDetalleFactura);
        detalleFactura_Modelo_Respuestas = await servicioDetalleFactura.Get_DetalleFacturas();
    }
}
