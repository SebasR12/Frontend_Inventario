@page "/Registrar_Producto/{idProducto:int?}"
@using Frontend_Inventario.Modelos
@using Frontend_Inventario.Servicios
@using Frontend_Inventario.Servicios.iServicios

@inject Producto_Interface servicioProducto
@inject NavigationManager navigationManager

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-lg rounded-4 border-0">
                <!-- Header con gradiente -->
                <div class="card-header text-center text-white rounded-top-4"
                     style="background: linear-gradient(90deg, #1e3c72, #2a5298);">
                    <h4 class="mb-0 fw-bold">Registro de Productos</h4>
                </div>

                <div class="card-body p-5">
                    <EditForm Model="producto_Modelo_Peticion" OnValidSubmit="@(() => GuardarProducto())" class="row g-4">

                        <!-- Nombre -->
                        <div class="col-md-6">
                            <label for="nombre" class="form-label fw-semibold">Nombre</label>
                            <InputText @bind-Value="producto_Modelo_Peticion.nombre"
                                       class="form-control form-control-lg shadow-sm border-0 rounded-pill"
                                       id="nombre"
                                       placeholder="Ingrese el nombre del producto" />
                        </div>

                        <!-- Descripción -->
                        <div class="col-md-6">
                            <label for="descripcion" class="form-label fw-semibold">Descripción</label>
                            <InputText @bind-Value="producto_Modelo_Peticion.descripcion"
                                       class="form-control form-control-lg shadow-sm border-0 rounded-pill"
                                       id="descripcion"
                                       placeholder="Ingrese la descripción" />
                        </div>

                        <!-- Precio de compra -->
                        <div class="col-md-6">
                            <label for="precioCompra" class="form-label fw-semibold">Precio de Compra</label>
                            <InputNumber @bind-Value="producto_Modelo_Peticion.precioCompra"
                                         class="form-control form-control-lg shadow-sm border-0 rounded-pill"
                                         id="precioCompra"
                                         placeholder="Ingrese el precio de compra" />
                        </div>

                        <!-- Precio de venta -->
                        <div class="col-md-6">
                            <label for="precioVenta" class="form-label fw-semibold">Precio de Venta</label>
                            <InputNumber @bind-Value="producto_Modelo_Peticion.precioVenta"
                                         class="form-control form-control-lg shadow-sm border-0 rounded-pill"
                                         id="precioVenta"
                                         placeholder="Ingrese el precio de venta" />
                        </div>

                        <!-- Stock actual -->
                        <div class="col-md-6">
                            <label for="stockActual" class="form-label fw-semibold">Stock Actual</label>
                            <InputNumber @bind-Value="producto_Modelo_Peticion.stockActual"
                                         class="form-control form-control-lg shadow-sm border-0 rounded-pill"
                                         id="stockActual"
                                         placeholder="Ingrese el stock actual" />
                        </div>

                        <!-- Stock mínimo -->
                        <div class="col-md-6">
                            <label for="stockMinimo" class="form-label fw-semibold">Stock Mínimo</label>
                            <InputNumber @bind-value="producto_Modelo_Peticion.stockMinimo"
                                         class="form-control form-control-lg shadow-sm border-0 rounded-pill"
                                         id="stockMinimo"
                                         placeholder="Ingrese el stock mínimo" />
                        </div>

                        <!-- Categoría -->
                        <div class="col-md-6">
                            <label for="idCategoria" class="form-label fw-semibold">ID Categoría</label>
                            <InputNumber @bind-Value="producto_Modelo_Peticion.idCategoria"
                                         class="form-control form-control-lg shadow-sm border-0 rounded-pill"
                                         id="idCategoria"
                                         placeholder="Ingrese el ID de categoría" />
                        </div>

                        <!-- Proveedor -->
                        <div class="col-md-6">
                            <label for="idProveedor" class="form-label fw-semibold">ID Proveedor</label>
                            <InputNumber @bind-Value="producto_Modelo_Peticion.idProveedor"
                                         class="form-control form-control-lg shadow-sm border-0 rounded-pill"
                                         id="idProveedor"
                                         placeholder="Ingrese el ID del proveedor" />
                        </div>

                        <hr class="my-4" />

                        <!-- Botones -->
                        <div class="col-12 text-center mt-4">
                            <a href="Lista_Producto"
                               class="btn btn-outline-secondary rounded-pill shadow-sm px-5 me-2"
                               style="transition: 0.3s; border-width: 2px;">
                                <i class="bi bi-backspace-fill me-2"></i> Volver
                            </a>

                            <button type="submit"
                                    class="btn btn-primary rounded-pill shadow-lg px-5"
                                    style="background: linear-gradient(90deg, #1e3c72, #2a5298); border: none; transition: 0.3s;">
                                <i class="bi bi-floppy-fill me-2"></i> Guardar
                            </button>
                        </div>

                    </EditForm>
                </div>
            </div>
        </div>
    </div>
</div>


@code {
    private Producto_Modelo_Peticion producto_Modelo_Peticion { get; set; } = new Producto_Modelo_Peticion();

    [Parameter]
    public int? idProducto { get; set; }

    private async Task GuardarProducto()
    {
        if(producto_Modelo_Peticion.idProducto > 0)
        {
            producto_Modelo_Peticion.proceso = 2;            
            var respuesta = await servicioProducto.Editar_Producto(producto_Modelo_Peticion);
        }else
        {
            producto_Modelo_Peticion.proceso = 1;
            producto_Modelo_Peticion.idProducto = 0;
            producto_Modelo_Peticion.margenGanancia = 0;
            var respuesta = await servicioProducto.Crear_Producto(producto_Modelo_Peticion);
        }        
        // Navegar de vuelta a la lista de productos después de guardar
        navigationManager.NavigateTo("Lista_Producto");
    }

    protected override async Task OnInitializedAsync()
    {
        if(idProducto.HasValue && idProducto.Value > 0)
        {
            var response = await servicioProducto.Get_Producto_ID(idProducto.Value);
            if(response != null)
            {
                producto_Modelo_Peticion.idProducto = response.ContainsKey("idProducto")
                ? Convert.ToInt32(response["idProducto"])
                : 0;
                producto_Modelo_Peticion.nombre = response.ContainsKey("nombre")
                ? response["nombre"]?.ToString()
                : string.Empty;
                producto_Modelo_Peticion.descripcion = response.ContainsKey("descripcion")
                ? response["descripcion"]?.ToString()
                : string.Empty;
                producto_Modelo_Peticion.precioCompra = response.ContainsKey("precioCompra")
                ? Convert.ToDecimal(response["precioCompra"])
                : 0;
                producto_Modelo_Peticion.precioVenta = response.ContainsKey("precioVenta")
                ? Convert.ToDecimal(response["precioVenta"])
                : 0;
                producto_Modelo_Peticion.margenGanancia = response.ContainsKey("margenGanancia")
                ? Convert.ToInt32(response["margenGanancia"])
                : 0;
                producto_Modelo_Peticion.stockActual = response.ContainsKey("stockActual")
                ? Convert.ToInt32(response["stockActual"])
                : 0;
                producto_Modelo_Peticion.stockMinimo = response.ContainsKey("stockMinimo")
                ? Convert.ToInt32(response["stockMinimo"])
                : 0;
                producto_Modelo_Peticion.idCategoria = response.ContainsKey("idCategoria")
                ? Convert.ToInt32(response["idCategoria"])
                : 0;
                producto_Modelo_Peticion.idProveedor = response.ContainsKey("idProveedor")
                ? Convert.ToInt32(response["idProveedor"])
                : 0;
            }
            else
            {
                Console.WriteLine("No se encontró el producto con el ID proporcionado.");
            }
        }
    }
}
